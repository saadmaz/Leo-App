# =============================================================
# LEO Frontend — Environment Variables
# Copy this file to .env.local for local dev,
# or add these as Environment Variables in Vercel.
# =============================================================

# URL of the deployed LEO backend (Railway / Fly.io / etc.)
# In local dev this is omitted — next.config.mjs defaults to http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=https://your-leo-api.up.railway.app

# ---- Firebase (Web SDK — public values, safe to commit) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Stripe (publishable key — safe to be public) ----------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...