# =============================================================
# LEO Backend - Environment Variables
# Copy this file to .env for local dev,
# or set these as Environment Variables in Railway.
# NEVER commit .env or service account files to git.
# =============================================================

# ---- Required ------------------------------------------------

# Anthropic (Claude) - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Firebase
# Option A: path to service account JSON file (local dev / Railway volume)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/backend/firebase-service-account.json
# Option B: inline credentials (preferred for Railway / Vercel env vars)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...    # from Stripe Dashboard → Webhooks → your endpoint
STRIPE_PRO_PRICE_ID=price_...      # Pro plan monthly price ID
STRIPE_AGENCY_PRICE_ID=price_...   # Agency plan monthly price ID

# ---- Brand Ingestion -----------------------------------------

# Firecrawl (website scraping) - firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Apify (Instagram scraping) - apify.com
APIFY_API_KEY=apify_api_...

# ---- App Config ----------------------------------------------

ENVIRONMENT=production             # development | production
LOG_LEVEL=INFO
FRONTEND_URL=https://your-leo-app.vercel.app   # exact origin, no trailing slash

# ---- Optional ------------------------------------------------

RESEND_API_KEY=re_...              # transactional email (future)
YOUTUBE_API_KEY=                   # YouTube channel ingestion (future)
